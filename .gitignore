data/splits/

# Large binaries — get these from HuggingFace instead of committing.
# The tokenizers are pulled lazily by `inference.embed_pdb` / `tokenize_pdb`
# from the model repo. Probing labels ship in the `k-fold-structure/repsp-benchmark`
# HF dataset as `probing/labels.pkl`.
code/tokenizer/backbone_tokenizer.pt
code/tokenizer/fullatom_tokenizer.pt
code/tokenizer/structure_tokenize/fullatom_tokenizer/fullatom_tokenizer.pt
code/repsp/probing/homomer/data/homomer_target_set.pkl
code/repsp/probing/homomer/data/homomer_target_set_plip.pkl

# Reference fixtures for the tokenizer regression test (regenerated locally).
